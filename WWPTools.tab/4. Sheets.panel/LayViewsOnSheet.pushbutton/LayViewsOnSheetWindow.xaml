<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lay Views on Sheet"
        Width="1320"
        Height="860"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FFF7F7F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Background="White"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="8">
            <DockPanel LastChildFill="True">
                <StackPanel>
                    <TextBlock x:Name="HeaderTitle"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="Lay Views on Sheet"/>
                    <TextBlock x:Name="HeaderSubtitle"
                               Margin="0,6,0,0"
                               Foreground="#66000000"
                               TextWrapping="Wrap"
                               Text="Create one new sheet from selected views. Drag the grey boxes to adjust viewport locations before placing them."/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="16"
                    Background="White"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Sheet Setup"/>

                        <TextBlock Margin="0,14,0,4"
                                   FontWeight="SemiBold"
                                   Text="Sheet number"/>
                        <TextBox x:Name="TxtSheetNumber"
                                 MinWidth="220"/>

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Sheet name"/>
                        <TextBox x:Name="TxtSheetName"
                                 MinWidth="220"/>

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Titleblock"/>
                        <ComboBox x:Name="CmbTitleblock"
                                  MinWidth="220"/>

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Viewport gap (mm)"/>
                        <TextBox x:Name="TxtGapMm"
                                 MinWidth="120"/>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#66000000"
                                   TextWrapping="Wrap"
                                   Text="Reset auto layout after changing the gap or titleblock. You can then drag individual boxes in the preview."/>

                        <Button x:Name="BtnAutoLayout"
                                Margin="0,12,0,0"
                                Height="34"
                                Content="Reset Auto Layout"/>
                    </StackPanel>

                    <Separator Grid.Row="2"/>

                    <TextBlock Grid.Row="4"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="Views"/>

                    <Grid Grid.Row="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="TxtViewSearch"
                                 Grid.Row="0"
                                 MinWidth="220"/>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal">
                            <Button x:Name="BtnSelectVisible"
                                    Width="100"
                                    Height="30"
                                    Content="Select Visible"/>
                            <Button x:Name="BtnClearVisible"
                                    Width="95"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Content="Clear Visible"/>
                        </StackPanel>

                        <Border Grid.Row="4"
                                BorderBrush="#22000000"
                                BorderThickness="1"
                                CornerRadius="6"
                                Background="#FFF9FAFB">
                            <ListBox x:Name="ViewsList"/>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="TxtViewSummary"
                               Grid.Row="8"
                               Foreground="#66000000"
                               TextWrapping="Wrap"
                               Text=""/>
                    <TextBlock x:Name="TxtWarning"
                               Grid.Row="9"
                               Margin="0,8,0,0"
                               Foreground="#C62828"
                               TextWrapping="Wrap"
                               Text=""/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"/>

            <Border Grid.Column="2"
                    Padding="16"
                    Background="White"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Sheet Preview"/>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#66000000"
                                   TextWrapping="Wrap"
                                   Text="Grey boxes represent viewport bounds. Drag them to set the final placement before creating the sheet."/>
                    </StackPanel>

                    <Border Grid.Row="2"
                            x:Name="PreviewHost"
                            Background="#FFF1F3F4"
                            BorderBrush="#22000000"
                            BorderThickness="1"
                            CornerRadius="8"
                            MinHeight="420">
                        <Canvas x:Name="PreviewCanvas"
                                ClipToBounds="True"
                                Background="Transparent"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="4"
                   LastChildFill="False">
            <TextBlock x:Name="FooterStatus"
                       VerticalAlignment="Center"
                       Foreground="#66000000"
                       Text=""/>
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Right">
                <Button x:Name="BtnCancel"
                        Width="110"
                        Height="34"
                        Margin="0,0,10,0"
                        Content="Cancel"/>
                <Button x:Name="BtnCreate"
                        Width="120"
                        Height="34"
                        Content="Create Sheet"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
