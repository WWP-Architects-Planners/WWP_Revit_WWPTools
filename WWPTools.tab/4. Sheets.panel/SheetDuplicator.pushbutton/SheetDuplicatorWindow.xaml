<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sheet Duplicator"
        Width="1380"
        Height="900"
        MinWidth="1120"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FFF7F7F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Background="White"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock x:Name="HeaderTitle"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="Sheet Duplicator"/>
                <TextBlock x:Name="HeaderSubtitle"
                           Margin="0,6,0,0"
                           Foreground="#66000000"
                           TextWrapping="Wrap"
                           Text="Duplicate one source sheet with the same viewport locations. Each viewport can get a newly duplicated view name before the new sheet is created."/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="16"
                    Background="White"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Sheet Setup"/>

                        <TextBlock Margin="0,14,0,4"
                                   FontWeight="SemiBold"
                                   Text="Source sheet"/>
                        <ComboBox x:Name="CmbSourceSheet"
                                  MinWidth="240"/>

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="Source titleblock"/>
                        <TextBlock x:Name="TxtTitleblock"
                                   Foreground="#66000000"
                                   TextWrapping="Wrap"
                                   Text=""/>

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="New sheet number"/>
                        <TextBox x:Name="TxtSheetNumber"
                                 MinWidth="180"/>

                        <TextBlock Margin="0,12,0,4"
                                   FontWeight="SemiBold"
                                   Text="New sheet name"/>
                        <TextBox x:Name="TxtSheetName"
                                 MinWidth="240"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,8,0">
                            <TextBlock FontWeight="SemiBold"
                                       Text="View duplicate mode"/>
                            <ComboBox x:Name="CmbDuplicateOption"
                                      Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="8,0,0,0">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Name template"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtViewPrefix"
                                         Grid.Column="0"/>
                                <TextBox x:Name="TxtViewSuffix"
                                         Grid.Column="2"/>
                            </Grid>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#66000000"
                                       Text="Prefix and suffix for newly duplicated view names."
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="4">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Viewport Assignments"/>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#66000000"
                                   TextWrapping="Wrap"
                                   Text="Each row duplicates the source view and places it back on the new sheet at the same viewport location. Views that cannot duplicate will reuse the source view."/>
                    </StackPanel>

                    <Border Grid.Row="6"
                            BorderBrush="#22000000"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="#FFF9FAFB">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="AssignmentsHost"
                                        Margin="8"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="8">
                        <Button x:Name="BtnResetNames"
                                Width="150"
                                Height="32"
                                HorizontalAlignment="Left"
                                Content="Reset Target Names"/>
                        <TextBlock x:Name="TxtSummary"
                                   Margin="0,10,0,0"
                                   Foreground="#66000000"
                                   TextWrapping="Wrap"
                                   Text=""/>
                        <TextBlock x:Name="TxtWarning"
                                   Margin="0,8,0,0"
                                   Foreground="#C62828"
                                   TextWrapping="Wrap"
                                   Text=""/>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"/>

            <Border Grid.Column="2"
                    Padding="16"
                    Background="White"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Sheet Preview"/>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#66000000"
                                   TextWrapping="Wrap"
                                   Text="Grey boxes show the source sheet layout. The new sheet keeps these viewport locations while using the assigned duplicate view names."/>
                    </StackPanel>

                    <Border Grid.Row="2"
                            x:Name="PreviewHost"
                            Background="#FFF1F3F4"
                            BorderBrush="#22000000"
                            BorderThickness="1"
                            CornerRadius="8"
                            MinHeight="420">
                        <Canvas x:Name="PreviewCanvas"
                                ClipToBounds="True"
                                Background="Transparent"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="4"
                   LastChildFill="False">
            <TextBlock x:Name="FooterStatus"
                       VerticalAlignment="Center"
                       Foreground="#66000000"
                       Text=""/>
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Right">
                <Button x:Name="BtnCancel"
                        Width="110"
                        Height="34"
                        Margin="0,0,10,0"
                        Content="Cancel"/>
                <Button x:Name="BtnCreate"
                        Width="130"
                        Height="34"
                        Content="Duplicate Sheet"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
