<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Combined Print Set"
        Width="1520"
        Height="920"
        MinWidth="1260"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FFF7F7F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Background="White"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock x:Name="HeaderTitle"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="Combined Print Set"/>
                <TextBlock x:Name="HeaderSubtitle"
                           Margin="0,6,0,0"
                           Foreground="#66000000"
                           TextWrapping="Wrap"
                           Text="Load sheets from open or closed Revit models, arrange the final order, and print one merged PDF drawing set."/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="16"
                    Background="White"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="160"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               LastChildFill="False">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="Source Models"/>
                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Right">
                            <Button x:Name="BtnAddFiles"
                                    Width="110"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Content="Add Files"/>
                            <Button x:Name="BtnRemoveSource"
                                    Width="120"
                                    Height="30"
                                    Content="Remove Source"/>
                        </StackPanel>
                    </DockPanel>

                    <ListBox x:Name="SourcesList"
                             Grid.Row="2"/>

                    <TextBlock Grid.Row="4"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="Available Sheets"/>

                    <TextBox x:Name="TxtSheetFilter"
                             Grid.Row="6"
                             Height="30"
                             VerticalContentAlignment="Center"
                             ToolTip="Filter sheets in the selected source model"/>

                    <ListBox x:Name="AvailableSheetsList"
                             Grid.Row="8"
                             SelectionMode="Extended"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center">
                <Button x:Name="BtnAddSelected"
                        Height="34"
                        Margin="0,0,0,10"
                        Content="Add >"/>
                <Button x:Name="BtnAddAll"
                        Height="34"
                        Margin="0,0,0,10"
                        Content="Add All >>"/>
            </StackPanel>

            <Border Grid.Column="4"
                    Padding="16"
                    Background="White"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Ordered Print Set"/>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#66000000"
                                   TextWrapping="Wrap"
                                   Text="The right-hand list defines the final PDF page order. Use the move buttons to sort sheets across models."/>
                    </StackPanel>

                    <ListBox x:Name="SelectedSheetsList"
                             Grid.Row="2"
                             SelectionMode="Extended"/>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal">
                            <TextBlock x:Name="TxtSummary"
                                       VerticalAlignment="Center"
                                       Foreground="#66000000"
                                       TextWrapping="Wrap"
                                       Text=""/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontWeight="SemiBold"
                                       Text="PDF Printer"/>
                            <ComboBox x:Name="CmbPrinter"
                                      Margin="0,4,0,0"
                                      MinWidth="340"/>

                            <TextBlock Margin="0,12,0,0"
                                       FontWeight="SemiBold"
                                       Text="Output PDF"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtOutputPath"
                                         Grid.Column="0"
                                         MinWidth="360"/>
                                <Button x:Name="BtnBrowseOutput"
                                        Grid.Column="2"
                                        Height="30"
                                        Content="Browse"/>
                            </Grid>

                            <TextBlock x:Name="TxtWarning"
                                       Margin="0,10,0,0"
                                       Foreground="#C62828"
                                       TextWrapping="Wrap"
                                       Text=""/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Column="5"
                        VerticalAlignment="Center">
                <Button x:Name="BtnMoveTop"
                        Height="32"
                        Margin="0,0,0,8"
                        Content="Top"/>
                <Button x:Name="BtnMoveUp"
                        Height="32"
                        Margin="0,0,0,8"
                        Content="Up"/>
                <Button x:Name="BtnMoveDown"
                        Height="32"
                        Margin="0,0,0,8"
                        Content="Down"/>
                <Button x:Name="BtnMoveBottom"
                        Height="32"
                        Margin="0,0,0,16"
                        Content="Bottom"/>
                <Button x:Name="BtnRemoveSelected"
                        Height="32"
                        Margin="0,0,0,8"
                        Content="Remove"/>
                <Button x:Name="BtnClearSet"
                        Height="32"
                        Content="Clear"/>
            </StackPanel>
        </Grid>

        <DockPanel Grid.Row="4"
                   LastChildFill="False">
            <TextBlock x:Name="FooterStatus"
                       VerticalAlignment="Center"
                       Foreground="#66000000"
                       Text=""/>
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Right">
                <Button x:Name="BtnCancel"
                        Width="110"
                        Height="34"
                        Margin="0,0,10,0"
                        Content="Cancel"/>
                <Button x:Name="BtnPrint"
                        Width="150"
                        Height="34"
                        Content="Print PDF Set"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
