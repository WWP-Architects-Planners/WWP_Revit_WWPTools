<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Web Context Builder"
        Height="760"
        Width="760"
        MinHeight="700"
        MinWidth="680"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#FFF6F7FB"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                Background="White"
                BorderBrush="#FFD7DCE6"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image x:Name="LogoImage"
                       Grid.Column="0"
                       Width="48"
                       Height="48"
                       Margin="0,0,12,0"
                       Stretch="Uniform"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Web Context Builder"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#FF1D2738"/>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF5E6B80"
                               TextWrapping="Wrap">
                        Imports buildings as Mass and roads, parks, and water as Floors from OpenStreetMap.
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="18"
                Background="White"
                BorderBrush="#FFD7DCE6"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="260"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,12,12"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#FF1D2738"
                           Text="Address"/>
                <TextBox x:Name="AddressTextBox"
                         Grid.Row="0"
                         Grid.Column="1"
                         Margin="0,0,0,12"
                         MinHeight="30"
                         Padding="8,4"/>
                <Button x:Name="LocateButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Margin="12,0,0,12"
                        MinWidth="84"
                        Height="30"
                        Background="White"
                        BorderBrush="#FFD7DCE6"
                        Content="Locate"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,12,12"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#FF1D2738"
                           Text="Radius (m)"/>
                <TextBox x:Name="RadiusTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,0,12"
                         MinHeight="30"
                         Padding="8,4"/>

                <TextBlock Grid.Row="2"
                           Grid.ColumnSpan="3"
                           Margin="0,0,0,8"
                           Foreground="#FF5E6B80"
                           TextWrapping="Wrap">
                    Leave Address blank to use the project site location when available. Click the map to set a location and reverse-geocode it back into the address field.
                </TextBlock>

                <Border Grid.Row="3"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,8"
                        Background="#FFF2F5FA"
                        BorderBrush="#FFD7DCE6"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0"
                                   Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left"
                                       FontWeight="SemiBold"
                                       Foreground="#FF1D2738"
                                       Text="Map Preview"/>
                            <TextBlock x:Name="MapHintText"
                                       Margin="12,0,0,0"
                                       Foreground="#FF5E6B80"
                                       Text="Click map to choose the import center."/>
                        </DockPanel>
                        <Border Grid.Row="1"
                                Background="White"
                                BorderBrush="#FFD7DCE6"
                                BorderThickness="1"
                                CornerRadius="6"
                                ClipToBounds="True">
                            <WebBrowser x:Name="MapBrowser"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,8"
                        Padding="12"
                        Background="#FFF2F5FA"
                        BorderBrush="#FFD7DCE6"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#FF1D2738"
                                   Text="Layers"/>
                        <WrapPanel Grid.Row="1"
                                   Margin="0,8,0,0">
                            <CheckBox x:Name="BuildingsCheckBox"
                                      Margin="0,0,18,8"
                                      IsChecked="True"
                                      Content="Buildings"/>
                            <CheckBox x:Name="RoadsCheckBox"
                                      Margin="0,0,18,8"
                                      IsChecked="True"
                                      Content="Roads"/>
                            <CheckBox x:Name="ParksCheckBox"
                                      Margin="0,0,18,8"
                                      IsChecked="True"
                                      Content="Parks"/>
                            <CheckBox x:Name="WaterCheckBox"
                                      Margin="0,0,18,8"
                                      IsChecked="True"
                                      Content="Water"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="5"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,8"
                        Padding="12"
                        Background="#FFF2F5FA"
                        BorderBrush="#FFD7DCE6"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#FF1D2738"
                                   Text="Automatic Outputs"/>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#FF5E6B80"
                                   TextWrapping="Wrap"
                                   Text="Buildings -> Mass category shapes&#x0a;Roads -> Floor elements from buffered centerlines&#x0a;Parks and Water -> Floor elements from area data"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ValidationText"
                           Grid.Row="6"
                           Grid.ColumnSpan="3"
                           Foreground="#FFB42318"
                           FontWeight="SemiBold"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="RunButton"
                    Width="110"
                    Height="34"
                    Margin="0,0,10,0"
                    Background="#FF2D6CDF"
                    Foreground="White"
                    BorderBrush="#FF2D6CDF"
                    Content="Run"/>
            <Button x:Name="CancelButton"
                    Width="110"
                    Height="34"
                    Background="White"
                    BorderBrush="#FFD7DCE6"
                    Content="Cancel"/>
        </StackPanel>
    </Grid>
</Window>
