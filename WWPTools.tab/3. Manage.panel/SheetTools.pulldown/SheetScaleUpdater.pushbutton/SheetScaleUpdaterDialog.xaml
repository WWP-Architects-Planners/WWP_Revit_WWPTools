<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sheet Scale Updater"
        Width="980"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="Segoe UI"
        FontSize="14"
        Background="#F3F5F7">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#F3F5F7" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="FieldBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3F9AD9" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#2E87C5" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="TextBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="DangerBrush" Color="#C43D3D" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FlatTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinHeight" Value="38" />
        </Style>

        <Style x:Key="FlatComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="38" />
        </Style>

        <Style x:Key="FlatListBox" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <Style x:Key="FlatListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FB" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#DCEFFC" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#A9D0EE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="26.5" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>

        <Style x:Key="ToggleSwitchCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Width="38"
                                  Height="19"
                                  VerticalAlignment="Center">
                                <Border x:Name="SwitchTrack"
                                        Background="#B8C1CC"
                                        BorderBrush="#AEB8C4"
                                        BorderThickness="1"
                                        CornerRadius="9.5" />
                                <Ellipse x:Name="SwitchThumb"
                                         Width="15"
                                         Height="15"
                                         Margin="2,2,21,2"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Fill="White"
                                         Stroke="#AEB8C4"
                                         StrokeThickness="1" />
                            </Grid>

                            <ContentPresenter Grid.Column="1"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="21,2,2,2" />
                                <Setter TargetName="SwitchThumb" Property="Stroke" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}" Margin="16">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="#D7DEE6"
                BorderThickness="1"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Sheet Scale Updater"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="PromptText"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedBrush}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Target Parameter"
                                   Margin="0,0,0,6"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="ParameterCombo"
                                  MinWidth="320"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  StaysOpenOnEdit="True"
                                  Style="{StaticResource FlatComboBox}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sheet Search"
                                   Margin="0,0,0,6"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="SearchBox"
                                 MinWidth="260"
                                 Style="{StaticResource FlatTextBox}" />
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="IgnoreDraftingViewsCheckBox"
                          Grid.Row="2"
                          Content="Ignore Drafting Views when calculating sheet scale"
                          Margin="0,0,0,14"
                          Style="{StaticResource ToggleSwitchCheckBox}" />

                <StackPanel Grid.Row="3" Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock Text="Select sheets to update"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <CheckBox x:Name="AllSheetsCheckBox"
                                  Content="All Sheets"
                                  DockPanel.Dock="Right"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource ToggleSwitchCheckBox}" />
                    </DockPanel>
                    <TextBlock x:Name="AllSheetsWarningText"
                               Text="To update individual sheets, uncheck the 'All Sheets' option."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               FontStyle="Italic"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ListBox x:Name="SheetsList"
                         Grid.Row="4"
                         SelectionMode="Extended"
                         MinHeight="320"
                         Margin="0,0,0,8"
                         Style="{StaticResource FlatListBox}"
                         ItemContainerStyle="{StaticResource FlatListBoxItem}" />

                <TextBlock x:Name="ValidationText"
                           Grid.Row="5"
                           Foreground="{StaticResource DangerBrush}"
                           Visibility="Collapsed"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold" />

                <DockPanel Grid.Row="6" Margin="0,14,0,0">
                    <Image x:Name="LogoImage"
                           DockPanel.Dock="Left"
                           Width="52"
                           Height="52"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Left"
                           IsHitTestVisible="False" />
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="OkButton"
                                Content="OK"
                                MinWidth="110"
                                Margin="0,0,8,0"
                                IsDefault="True"
                                Style="{StaticResource PrimaryButton}" />
                        <Button x:Name="CancelButton"
                                Content="Cancel"
                                MinWidth="110"
                                IsCancel="True"
                                Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
