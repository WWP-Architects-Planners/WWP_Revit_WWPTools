<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copy Filters to Current View"
        Width="720"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F6F8FB"
        MinWidth="680"
        MinHeight="580">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="HeaderTitle" FontSize="22" FontWeight="SemiBold" Foreground="#17324D"/>
            <TextBlock x:Name="HeaderSubtitle" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#4F6478"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Source Template" FontWeight="SemiBold" Foreground="#17324D"/>
        <ComboBox x:Name="SourceTemplateCombo" Grid.Row="2" Margin="0,8,0,12" Height="32"/>

        <Border Grid.Row="3" CornerRadius="10" Background="White" BorderBrush="#D9E2EC" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Current View" FontWeight="SemiBold" Foreground="#17324D"/>
                <TextBlock x:Name="CurrentViewText" Margin="0,6,0,0" Foreground="#34495E" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" Text="Filters To Copy" FontWeight="SemiBold" Foreground="#17324D"/>

        <Grid Grid.Row="5" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilterSearchBox" Grid.Column="0" Height="30" VerticalContentAlignment="Center"/>
            <Button x:Name="BtnSelectVisibleFilters" Grid.Column="1" Margin="8,0,0,0" Padding="10,4" Content="Select Visible"/>
            <Button x:Name="BtnClearFilters" Grid.Column="2" Margin="8,0,0,0" Padding="10,4" Content="Clear"/>
        </Grid>

        <Border Grid.Row="6" CornerRadius="10" Background="White" BorderBrush="#D9E2EC" BorderThickness="1" Padding="8">
            <ListBox x:Name="FiltersList" SelectionMode="Extended" BorderThickness="0" Background="Transparent"/>
        </Border>

        <CheckBox x:Name="RemoveTemplateCheck" Grid.Row="7" Margin="0,12,0,0" Content="Remove any assigned view template from the current view before applying copied overrides." Foreground="#17324D"/>

        <TextBlock x:Name="WarningText" Grid.Row="8" Margin="0,10,0,0" Foreground="#B42318" Visibility="Collapsed" TextWrapping="Wrap"/>

        <Grid Grid.Row="9" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FooterStatus" Grid.Column="0" VerticalAlignment="Center" Foreground="#4F6478"/>
            <Button x:Name="BtnCancel" Grid.Column="1" Margin="8,0,0,0" MinWidth="110" Padding="14,8" Content="Cancel"/>
            <Button x:Name="BtnCopy" Grid.Column="2" Margin="8,0,0,0" MinWidth="140" Padding="14,8" Content="Copy Filters"/>
        </Grid>
    </Grid>
</Window>
