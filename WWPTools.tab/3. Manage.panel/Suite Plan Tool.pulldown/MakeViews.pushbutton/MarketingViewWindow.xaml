<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Make Marketing View"
    Width="720" Height="660"
    MinWidth="560" MinHeight="500"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResizeWithGrip"
    Background="#F6F8FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Make Marketing View"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="#17324D" TextWrapping="Wrap" />
            <TextBlock Text="Create a cropped marketing view and sheet for each selected area."
                       FontSize="12" Foreground="#4F6478"
                       Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Form body -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Area and Door info -->
                <Border Background="White" BorderBrush="#D9E2EC" BorderThickness="1"
                        Padding="14,10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Selected Area"
                                       FontSize="11" Foreground="#4F6478" />
                            <TextBlock x:Name="AreaLabel"
                                       Text="(not selected)"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#17324D" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Entry Door"
                                       FontSize="11" Foreground="#4F6478" />
                            <TextBlock x:Name="DoorLabel"
                                       Text="(not found)"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#17324D" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Sheet Settings section header -->
                <TextBlock Text="Sheet Settings"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#17324D" Margin="0,0,0,6" />

                <!-- Sheet Settings fields -->
                <Border Background="White" BorderBrush="#D9E2EC" BorderThickness="1"
                        Padding="14,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Sheet Number Parameter:"
                                   FontSize="12" Foreground="#17324D"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="SheetNumberParamCombo"
                                  Grid.Row="0" Grid.Column="1"
                                  Height="30" FontSize="12"
                                  Background="White" BorderBrush="#D9E2EC" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Sheet Name Parameter:"
                                   FontSize="12" Foreground="#17324D"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="SheetNameParamCombo"
                                  Grid.Row="2" Grid.Column="1"
                                  Height="30" FontSize="12"
                                  Background="White" BorderBrush="#D9E2EC" />
                    </Grid>
                </Border>

                <!-- View Settings section header -->
                <TextBlock Text="View Settings"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#17324D" Margin="0,0,0,6" />

                <!-- View Settings fields -->
                <Border Background="White" BorderBrush="#D9E2EC" BorderThickness="1"
                        Padding="14,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="View Template:"
                                   FontSize="12" Foreground="#17324D"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="TemplateCombo"
                                  Grid.Row="0" Grid.Column="1"
                                  Height="30" FontSize="12"
                                  Background="White" BorderBrush="#D9E2EC" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Titleblock:"
                                   FontSize="12" Foreground="#17324D"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="TitleblockCombo"
                                  Grid.Row="2" Grid.Column="1"
                                  Height="30" FontSize="12"
                                  Background="White" BorderBrush="#D9E2EC" />
                    </Grid>
                </Border>

                <!-- Options section header -->
                <TextBlock Text="Options"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#17324D" Margin="0,0,0,6" />

                <!-- Options fields -->
                <Border Background="White" BorderBrush="#D9E2EC" BorderThickness="1"
                        Padding="14,12" Margin="0,0,0,12">
                    <CheckBox x:Name="OverwriteCheckBox"
                              Content="Overwrite existing sheets with the same sheet number"
                              FontSize="12" Foreground="#17324D" />
                </Border>

                <!-- Keyplan section header -->
                <TextBlock Text="Keyplan"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#17324D" Margin="0,0,0,6" />

                <!-- Keyplan fields -->
                <Border Background="White" BorderBrush="#D9E2EC" BorderThickness="1"
                        Padding="14,12" Margin="0,0,0,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="KeyplanCheckBox"
                                  Grid.Row="0" Grid.ColumnSpan="2"
                                  Content="Create keyplan view alongside marketing view"
                                  FontSize="12" Foreground="#17324D" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Keyplan Template:"
                                   FontSize="12" Foreground="#17324D"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="KeyplanTemplateCombo"
                                  Grid.Row="2" Grid.Column="1"
                                  Height="30" FontSize="12"
                                  Background="White" BorderBrush="#D9E2EC" />

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="Fill Type:"
                                   FontSize="12" Foreground="#17324D"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="FillTypeCombo"
                                  Grid.Row="4" Grid.Column="1"
                                  Height="30" FontSize="12"
                                  Background="White" BorderBrush="#D9E2EC" />
                    </Grid>
                </Border>

                <!-- Validation text -->
                <TextBlock x:Name="ValidationText"
                           Foreground="#B42318" FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="CancelButton"
                        Content="Cancel" Width="90" Height="34"
                        FontSize="13"
                        Background="White" Foreground="#17324D"
                        BorderBrush="#D9E2EC" Cursor="Hand"
                        Margin="0,0,8,0" />
                <Button x:Name="OkButton"
                        Content="Create" Width="100" Height="34"
                        FontSize="13" FontWeight="SemiBold"
                        Background="#1976D2" Foreground="White"
                        BorderThickness="0" Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
