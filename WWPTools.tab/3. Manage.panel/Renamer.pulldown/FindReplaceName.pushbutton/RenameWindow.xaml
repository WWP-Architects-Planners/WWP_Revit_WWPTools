<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Super Renamer(by Selection)"
        Width="500"
        Height="430"
        MinWidth="420"
        MinHeight="390"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WWPTools.WpfUI;component/Themes/FlatTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="#E5EAF0" />
                <Setter Property="BorderBrush" Value="#CBD5E1" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
            <Style TargetType="Label">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Padding" Value="0,0,8,0" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Super Renamer(by Selection)"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Find and replace names for the current selection."
                       Margin="0,4,0,0"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12" />
        </StackPanel>

        <!-- Source info -->
        <TextBlock x:Name="TxtSource"
                   Grid.Row="2"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="11"
                   Text="Select elements in Revit, then click Preview &amp; Apply." />

        <!-- Find / Replace / Prefix / Suffix fields -->
        <Border Grid.Row="4"
                Padding="14,12"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Find:"
                       ToolTip="Text to search for within the existing name. Case-sensitive. Leave blank to only apply a Prefix or Suffix." />
                <TextBox x:Name="TxtFind" Grid.Row="0" Grid.Column="1"
                         ToolTip="Text to search for within the existing name. Case-sensitive. Leave blank to only apply a Prefix or Suffix." />

                <Label Grid.Row="2" Grid.Column="0" Content="Replace:"
                       ToolTip="Text to substitute in place of the found text. Leave blank to delete the found text without replacement." />
                <TextBox x:Name="TxtReplace" Grid.Row="2" Grid.Column="1"
                         ToolTip="Text to substitute in place of the found text. Leave blank to delete the found text without replacement." />

                <Label Grid.Row="4" Grid.Column="0" Content="Prefix:"
                       ToolTip="Text prepended to the start of every matched name. Applied after the Find/Replace step." />
                <TextBox x:Name="TxtPrefix" Grid.Row="4" Grid.Column="1"
                         ToolTip="Text prepended to the start of every matched name. Applied after the Find/Replace step." />

                <Label Grid.Row="6" Grid.Column="0" Content="Suffix:"
                       ToolTip="Text appended to the end of every matched name. Applied after the Find/Replace step." />
                <TextBox x:Name="TxtSuffix" Grid.Row="6" Grid.Column="1"
                         ToolTip="Text appended to the end of every matched name. Applied after the Find/Replace step." />
            </Grid>
        </Border>

        <!-- Buttons -->
        <DockPanel Grid.Row="6" Margin="0,16,0,0">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="BtnCancel"
                        MinWidth="90"
                        Margin="0,0,8,0"
                        Content="Cancel"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button x:Name="BtnApply"
                        MinWidth="150"
                        Content="Preview &amp; Apply"
                        IsDefault="True"
                        ToolTip="Preview all planned renames before committing any changes to the document." />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
