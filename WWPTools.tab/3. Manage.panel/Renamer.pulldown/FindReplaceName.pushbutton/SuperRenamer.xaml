<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Super Renamer"
        Width="500"
        Height="470"
        MinWidth="420"
        MinHeight="430"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WWPTools.WpfUI;component/Themes/FlatTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="#E5EAF0" />
                <Setter Property="BorderBrush" Value="#CBD5E1" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
            <Style TargetType="Label">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Padding" Value="0,0,8,0" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TxtHeader"
                       Text="Super Renamer"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock x:Name="TxtSubtitle"
                       Text="Find and replace names across your project."
                       Margin="0,4,0,0"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label x:Name="LblSelector" Grid.Column="0" Content="Category:" />
            <ComboBox x:Name="CmbCategory" Grid.Column="1" />
        </Grid>

        <TextBlock x:Name="TxtSource"
                   Grid.Row="4"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="11"
                   Text="Source: All elements in document" />

        <Border Grid.Row="6"
                Padding="14,12"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Find:" />
                <TextBox x:Name="TxtFind" Grid.Row="0" Grid.Column="1" />

                <Label Grid.Row="2" Grid.Column="0" Content="Replace:" />
                <TextBox x:Name="TxtReplace" Grid.Row="2" Grid.Column="1" />

                <Label Grid.Row="4" Grid.Column="0" Content="Prefix:" />
                <TextBox x:Name="TxtPrefix" Grid.Row="4" Grid.Column="1" />

                <Label Grid.Row="6" Grid.Column="0" Content="Suffix:" />
                <TextBox x:Name="TxtSuffix" Grid.Row="6" Grid.Column="1" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="8" Margin="0,16,0,0">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="BtnCancel"
                        MinWidth="90"
                        Margin="0,0,8,0"
                        Content="Cancel"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button x:Name="BtnApply"
                        MinWidth="150"
                        Content="Preview &amp; Apply"
                        IsDefault="True" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
