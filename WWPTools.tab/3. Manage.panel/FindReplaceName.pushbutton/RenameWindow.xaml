<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Rename"
        Height="700" Width="960"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Category + Search -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Category:" VerticalAlignment="Center"
                       FontWeight="SemiBold" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="1" x:Name="CboCategory" Height="28"/>
            <TextBlock Grid.Column="3" Text="Search:" VerticalAlignment="Center"
                       FontWeight="SemiBold" Margin="0,0,6,0"/>
            <TextBox Grid.Column="4" x:Name="TxtSearch" Height="28" Padding="4,3"/>
        </Grid>

        <!-- Row 1: Find / Replace / Prefix / Suffix -->
        <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1"
                CornerRadius="3" Padding="10,8" Margin="0,0,0,8" Background="#F7F7F7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Find:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox   Grid.Column="1" x:Name="TxtFind"    Height="26" Padding="4,2"/>
                <TextBlock Grid.Column="3" Text="Replace:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox   Grid.Column="4" x:Name="TxtReplace" Height="26" Padding="4,2"/>
                <TextBlock Grid.Column="6" Text="Prefix:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox   Grid.Column="7" x:Name="TxtPrefix"  Height="26" Padding="4,2"/>
                <TextBlock Grid.Column="9" Text="Suffix:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox   Grid.Column="10" x:Name="TxtSuffix" Height="26" Padding="4,2"/>
            </Grid>
        </Border>

        <!-- Row 2: Column headers + Select/Deselect buttons -->
        <Grid Grid.Row="2" Margin="0,0,0,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="36"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="Current Name"    FontWeight="Bold" FontSize="12" Foreground="#333"/>
            <TextBlock Grid.Column="2" Text="New Name Preview" FontWeight="Bold" FontSize="12" Foreground="#333" Margin="8,0,0,0"/>
            <Button Grid.Column="3" x:Name="BtnSelectAll"   Content="Select All"   Padding="8,3" Margin="0,0,6,0" FontSize="11"/>
            <Button Grid.Column="4" x:Name="BtnDeselectAll" Content="Deselect All" Padding="8,3" FontSize="11"/>
        </Grid>

        <!-- Row 3: Scrollable item list -->
        <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ItemsPanel" Margin="2,2,2,2"/>
            </ScrollViewer>
        </Border>

        <!-- Row 4: Status labels + Cancel / Rename -->
        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="LblCount"  Text="" Foreground="#666666" FontSize="12"/>
                <TextBlock x:Name="LblStatus" Text="" Foreground="#007700" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="BtnCancel" Content="Cancel" Width="80"  Height="30"/>
            <Button Grid.Column="3" x:Name="BtnRename" Content="Rename" Width="100" Height="30"/>
        </Grid>
    </Grid>
</Window>
