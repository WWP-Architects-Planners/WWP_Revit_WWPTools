<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Publish Fire Rating to Doors"
    Width="480" Height="300"
    MinWidth="400" MinHeight="260"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResizeWithGrip"
    Background="#F6F8FB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Publish Fire Rating to Doors"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="#17324D" TextWrapping="Wrap"/>
            <TextBlock Text="Copies FRR and STC parameter values from host walls to doors."
                       FontSize="12" Foreground="#4F6478"
                       Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- FRR Param -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="FRR Parameter Name:"
                       VerticalAlignment="Center"
                       Foreground="#17324D" FontSize="13"/>
            <TextBox Grid.Column="1" x:Name="TxtFrrParam"
                     Height="32" Padding="8,4"
                     BorderBrush="#D9E2EC" BorderThickness="1"
                     FontSize="13" VerticalContentAlignment="Center"/>
        </Grid>

        <!-- STC Param -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="STC Parameter Name:"
                       VerticalAlignment="Center"
                       Foreground="#17324D" FontSize="13"/>
            <TextBox Grid.Column="1" x:Name="TxtStcParam"
                     Height="32" Padding="8,4"
                     BorderBrush="#D9E2EC" BorderThickness="1"
                     FontSize="13" VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="3" x:Name="LblStatus"
                   Foreground="#B42318" FontSize="12"
                   Margin="0,4,0,8" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="BtnCancel"
                    Content="Cancel" Width="90" Height="34"
                    FontSize="13"
                    Background="White" BorderBrush="#D9E2EC"
                    Foreground="#17324D" Cursor="Hand"/>
            <Button Grid.Column="3" x:Name="BtnRun"
                    Content="Publish" Width="90" Height="34"
                    FontSize="13" FontWeight="SemiBold"
                    Background="#17324D" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
