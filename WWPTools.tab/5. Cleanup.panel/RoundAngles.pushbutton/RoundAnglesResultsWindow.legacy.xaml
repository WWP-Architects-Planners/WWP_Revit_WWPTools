<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Round Off-Axis Sketch Lines Results"
        Width="1180"
        Height="820"
        MinWidth="960"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WWPTools.WpfUI;component/Themes/FlatTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="#E5EAF0" />
                <Setter Property="BorderBrush" Value="#CBD5E1" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="HeaderTitle"
                       FontSize="18"
                       FontWeight="Bold"
                       Text="Round Off-Axis Sketch Lines Results" />
            <TextBlock x:Name="HeaderSubtitle"
                       Margin="0,4,0,0"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       TextWrapping="Wrap"
                       Text="Click a row to highlight the element in Revit." />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="14"
                Margin="0,0,0,12"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock x:Name="TxtSummary"
                           FontWeight="SemiBold"
                           Text="Matched warnings: 0 Updated: 0 Failed: 0" />
                <TextBlock x:Name="TxtSkipped"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedBrush}"
                           Text="Skipped: None" />
                <TextBlock Margin="0,10,0,0"
                           FontWeight="SemiBold"
                           Text="Log File" />
                <TextBox x:Name="TxtLogPath"
                         Margin="0,4,0,0"
                         IsReadOnly="True" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="360" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold"
                               Text="Results" />
                    <Grid Grid.Row="1"
                          Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel x:Name="SelectionToolbar"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <Button x:Name="BtnRemoveSelected"
                                    MinWidth="118"
                                    Margin="0,0,8,0"
                                    Content="Remove Selected"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="BtnResetList"
                                    MinWidth="92"
                                    Content="Reset List"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                        <ListBox x:Name="ResultsList"
                                 Grid.Row="1"
                                 SelectionMode="Extended" />
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          Background="#D7DEE8"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="2"
                    Padding="12"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold"
                               Text="Selected Item" />
                    <TextBox x:Name="TxtDetail"
                             Grid.Row="1"
                             Margin="0,10,0,0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True" />
                    <UniformGrid Grid.Row="2"
                                 Margin="0,12,0,0"
                                 Columns="2"
                                 Rows="3">
                        <Button x:Name="BtnSelect"
                                Margin="0,0,8,8"
                                MinWidth="0"
                                Content="Select" />
                        <Button x:Name="BtnGoToView"
                                Margin="0,0,0,8"
                                MinWidth="0"
                                Content="Go To View"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button x:Name="BtnEditBoundary"
                                Margin="0,0,8,8"
                                MinWidth="0"
                                Content="Edit Boundary"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button x:Name="BtnZoom"
                                Margin="0,0,0,8"
                                MinWidth="0"
                                Content="Zoom To"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button x:Name="BtnIsolate"
                                Margin="0,0,8,0"
                                MinWidth="0"
                                Content="Isolate"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button x:Name="BtnApply"
                        MinWidth="100"
                        Margin="0,0,8,0"
                        Content="Apply"
                        Visibility="Collapsed" />
                <Button x:Name="BtnClose"
                        MinWidth="100"
                        Content="Close"
                        IsDefault="True" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
