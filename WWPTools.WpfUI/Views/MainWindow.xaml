<Window x:Class="WWPTools.WpfUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WWPTools"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WWPTools.WpfUI;component/Themes/FlatTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="#D7DEE6"
                BorderThickness="1"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,16">
                    <Viewbox Width="56" Height="56" Margin="0,0,16,0">
                        <Canvas Width="64" Height="64">
                            <Path Fill="#1F2937" Data="M32,4 L60,20 L60,44 L32,60 L4,44 L4,20 Z" />
                            <Path Fill="#3F9AD9" Data="M32,12 L52,23 L52,41 L32,52 L12,41 L12,23 Z" />
                        </Canvas>
                    </Viewbox>
                    <StackPanel>
                        <TextBlock Text="WWPTools" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Suite Plan Tools" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#FFFFFF"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="Project Info" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Project Name" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <TextBox Margin="0,4,0,12" />
                            <TextBlock Text="Client" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <TextBox Margin="0,4,0,12" />
                            <TextBlock Text="Suite Count" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <TextBox Margin="0,4,0,12" />
                            <TextBlock Text="Template" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <ComboBox Margin="0,4,0,0">
                                <ComboBoxItem Content="Default" />
                                <ComboBoxItem Content="Marketing" />
                                <ComboBoxItem Content="Leasing" />
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="16,0,0,0"
                            Background="#FFFFFF"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="Options" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <CheckBox Content="Create Key Plan" Margin="0,0,0,8" />
                            <CheckBox Content="Create Suite Views" Margin="0,0,0,8" />
                            <CheckBox Content="Apply View Template" Margin="0,0,0,8" />
                            <CheckBox Content="Place on Sheets" Margin="0,0,0,8" />
                            <CheckBox Content="Generate Marketing Exports" />
                        </StackPanel>
                    </Border>
                </Grid>

                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Left" Text="Ready" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Cancel" Width="90" Margin="0,0,8,0" Background="#FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}" />
                        <Button Content="Run" Width="120" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
