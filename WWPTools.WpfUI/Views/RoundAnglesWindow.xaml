<Window x:Class="WWPTools.WpfUI.Views.RoundAnglesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Round Off-Axis Sketch Lines"
        Width="1260"
        Height="820"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WWPTools.WpfUI;component/Themes/FlatTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="#D7DEE6"
                BorderThickness="1"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,12">
                    <TextBlock x:Name="HeaderTitle"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"
                               Text="Round Off-Axis Sketch Lines" />
                    <TextBlock x:Name="HeaderSubtitle"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Text="Modeless warning browser. Refresh the list, inspect hosts, edit groups manually, then apply only the remaining rows." />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,0,0,12"
                        BorderBrush="#D7DEE6"
                        BorderThickness="1"
                        Padding="12">
                    <StackPanel>
                        <TextBlock x:Name="TxtSummary"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"
                                   Text="Matched warnings: 0    Pending fixes: 0" />
                        <TextBlock x:Name="TxtSkipped"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap"
                                   Text="Skipped: None" />
                        <TextBlock Text="Log File"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <TextBox x:Name="TxtLogPath"
                                 IsReadOnly="True"
                                 Text="(log file is written after apply)" />
                    </StackPanel>
                </Border>

                <UniformGrid Grid.Row="2"
                             Columns="5"
                             Margin="0,0,0,12">
                    <Button x:Name="BtnRefresh"
                            Content="Refresh"
                            Margin="0,0,8,0" />
                    <Button x:Name="BtnRemoveSelected"
                            Content="Remove Selected"
                            Margin="0,0,8,0" />
                    <Button x:Name="BtnResetList"
                            Content="Reset List"
                            Margin="0,0,8,0" />
                    <Button x:Name="BtnApply"
                            Content="Apply"
                            Margin="0,0,8,0" />
                    <Button x:Name="BtnClose"
                            Content="Close" />
                </UniformGrid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.15*" />
                        <ColumnDefinition Width="1.05*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Results"
                              Margin="0,0,10,0">
                        <ListBox x:Name="ResultsList"
                                 DisplayMemberPath="DisplayText"
                                 SelectionMode="Extended"
                                 HorizontalContentAlignment="Stretch" />
                    </GroupBox>

                    <GroupBox Grid.Column="1"
                              Header="Selected Item">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox x:Name="TxtDetail"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled" />

                            <UniformGrid Grid.Row="1"
                                         Columns="2"
                                         Margin="0,12,0,0">
                                <Button x:Name="BtnSelect"
                                        Content="Select"
                                        Margin="0,0,8,8" />
                                <Button x:Name="BtnGoToView"
                                        Content="Go To View"
                                        Margin="0,0,0,8" />
                                <Button x:Name="BtnEditGroup"
                                        Content="Edit Group"
                                        Margin="0,0,8,8" />
                                <Button x:Name="BtnEditBoundary"
                                        Content="Edit Boundary"
                                        Margin="0,0,0,8" />
                                <Button x:Name="BtnZoom"
                                        Content="Zoom To"
                                        Margin="0,0,8,8" />
                                <Button x:Name="BtnIsolate"
                                        Content="Isolate"
                                        Margin="0,0,0,8" />
                            </UniformGrid>
                        </Grid>
                    </GroupBox>
                </Grid>

                <DockPanel Grid.Row="4"
                           Margin="0,12,0,0">
                    <Image x:Name="LogoImage"
                           DockPanel.Dock="Left"
                           Width="56"
                           Height="56"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Left"
                           IsHitTestVisible="False" />
                    <TextBlock x:Name="FooterText"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Bottom"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Selection follows the highest parent element available." />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
