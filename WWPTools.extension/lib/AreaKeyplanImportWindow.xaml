<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Area Key Schedule"
        Width="980"
        Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="#D7DEE6"
                BorderThickness="1"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               Text="Excel File" />
                    <TextBox x:Name="FilePathBox"
                             Grid.Column="1"
                             Margin="8,0,0,0"
                             MinWidth="420"
                             IsReadOnly="True" />
                    <Button x:Name="BrowseButton"
                            Grid.Column="2"
                            Content="Browse"
                            MinWidth="110"
                            Margin="8,0,0,0" />
                    <Button x:Name="LoadButton"
                            Grid.Column="3"
                            Content="Load"
                            MinWidth="110"
                            Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"
                               Text="Schedule Type" />
                    <ComboBox x:Name="TargetTypeCombo"
                              Grid.Column="1"
                              Margin="8,0,0,0"
                              MinWidth="260" />
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Map Excel columns to parameters"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,0,0,8" />

                <DataGrid x:Name="MappingGrid"
                          Grid.Row="3"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          HeadersVisibility="Column"
                          VirtualizingPanel.IsVirtualizing="False"
                          Margin="0,0,0,8"
                          MinHeight="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Excel Column"
                                            Binding="{Binding ColumnName}"
                                            IsReadOnly="True"
                                            Width="2*" />
                        <DataGridTemplateColumn Header="Map To"
                                                Width="3*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding Options}"
                                              SelectedItem="{Binding SelectedOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <DockPanel Grid.Row="4">
                    <Image x:Name="LogoImage"
                           DockPanel.Dock="Left"
                           Width="56"
                           Height="56"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Left"
                           IsHitTestVisible="False" />
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button x:Name="OkButton"
                                Content="OK"
                                MinWidth="100"
                                Margin="0,0,8,0"
                                IsDefault="True" />
                        <Button x:Name="CancelButton"
                                Content="Cancel"
                                MinWidth="100"
                                IsCancel="True" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
