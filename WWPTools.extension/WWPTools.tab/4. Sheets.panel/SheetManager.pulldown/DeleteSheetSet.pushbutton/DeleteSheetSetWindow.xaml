<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Delete Sheet Set"
    Width="1000" Height="680"
    MinWidth="720" MinHeight="500"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResizeWithGrip"
    Background="#F6F8FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Delete Sheet Set"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="#17324D" TextWrapping="Wrap" />
            <TextBlock Text="Filter by parameter, search, and delete the selected set while continuing to work in Revit."
                       FontSize="12" Foreground="#4F6478"
                       Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Main: left filter sidebar + splitter + right lists -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="160" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: filter controls -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="120" MaxHeight="160" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Filter Parameter label -->
                <TextBlock Grid.Row="0"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#17324D" Text="Filter Parameter" />

                <!-- Filter parameter combo -->
                <ComboBox x:Name="FilterParamCombo"
                          Grid.Row="2"
                          Height="30"
                          FontSize="12"
                          Background="White"
                          BorderBrush="#D9E2EC" />

                <!-- Value label -->
                <TextBlock Grid.Row="4"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#17324D" Text="Value" />

                <!-- Apply + Clear buttons on same row as Value label -->
                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="ApplyFilterButton"
                            Content="Apply" Width="64" Height="24"
                            FontSize="11"
                            Background="#1976D2" Foreground="White"
                            BorderThickness="0" Cursor="Hand" />
                    <Button x:Name="ClearFilterButton"
                            Content="Clear" Width="52" Height="24"
                            FontSize="11"
                            Background="White" Foreground="#17324D"
                            BorderBrush="#D9E2EC" Margin="4,0,0,0"
                            Cursor="Hand" />
                </StackPanel>

                <!-- Value list -->
                <Border Grid.Row="6"
                        BorderBrush="#D9E2EC" BorderThickness="1"
                        Background="White">
                    <ListBox x:Name="FilterValueList"
                             SelectionMode="Extended"
                             BorderThickness="0"
                             FontSize="12"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Border>

                <!-- Search label -->
                <TextBlock Grid.Row="8"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#17324D" Text="Search" />

                <!-- Search box -->
                <TextBox x:Name="SearchBox"
                         Grid.Row="10"
                         Height="30"
                         FontSize="12"
                         VerticalContentAlignment="Center"
                         Padding="6,0"
                         BorderBrush="#D9E2EC"
                         Background="White" />

                <!-- Select All / None / Invert -->
                <WrapPanel Grid.Row="12" Orientation="Horizontal">
                    <Button x:Name="SelectAllButton"
                            Content="Select All" Width="88" Height="28"
                            FontSize="11"
                            Background="White" Foreground="#17324D"
                            BorderBrush="#D9E2EC"
                            Margin="0,0,4,4" Cursor="Hand" />
                    <Button x:Name="SelectNoneButton"
                            Content="None" Width="64" Height="28"
                            FontSize="11"
                            Background="White" Foreground="#17324D"
                            BorderBrush="#D9E2EC"
                            Margin="0,0,4,4" Cursor="Hand" />
                    <Button x:Name="InvertButton"
                            Content="Invert" Width="64" Height="28"
                            FontSize="11"
                            Background="White" Foreground="#17324D"
                            BorderBrush="#D9E2EC"
                            Margin="0,0,0,4" Cursor="Hand" />
                </WrapPanel>

                <!-- Count label -->
                <TextBlock x:Name="CountLabel"
                           Grid.Row="14"
                           FontSize="11"
                           Foreground="#4F6478"
                           TextWrapping="Wrap"
                           VerticalAlignment="Bottom" />
            </Grid>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D9E2EC"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <!-- RIGHT: available + to-delete lists -->
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Available sheets -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#17324D" Text="Available Sheets" />
                    <Border Grid.Row="2"
                            BorderBrush="#D9E2EC" BorderThickness="1"
                            Background="White">
                        <ListBox x:Name="AvailableList"
                                 BorderThickness="0"
                                 FontSize="12"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Grid>

                <!-- Sheets to delete -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#17324D" Text="Sheets To Delete" />
                    <Border Grid.Row="2"
                            BorderBrush="#D9E2EC" BorderThickness="1"
                            Background="#FAFBFC">
                        <ListBox x:Name="PreviewList"
                                 BorderThickness="0"
                                 FontSize="12"
                                 Foreground="#4F6478"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="ValidationText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="#B42318"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="RefreshButton"
                        Content="Refresh" Width="90" Height="34"
                        FontSize="13"
                        Background="White" Foreground="#17324D"
                        BorderBrush="#D9E2EC"
                        Margin="0,0,8,0" Cursor="Hand" />
                <Button x:Name="DeleteButton"
                        Content="Delete Selected" Width="140" Height="34"
                        FontSize="13" FontWeight="SemiBold"
                        Background="#B42318" Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,8,0" Cursor="Hand" />
                <Button x:Name="CloseButton"
                        Content="Close" Width="90" Height="34"
                        FontSize="13"
                        Background="White" Foreground="#17324D"
                        BorderBrush="#D9E2EC"
                        Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
