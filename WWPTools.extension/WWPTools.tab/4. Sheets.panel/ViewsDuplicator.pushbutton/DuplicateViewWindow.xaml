<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Views Duplicator"
        Width="500"
        Height="530"
        MinWidth="420"
        MinHeight="480"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WWPTools.WpfUI;component/Themes/FlatTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="#E5EAF0" />
                <Setter Property="BorderBrush" Value="#CBD5E1" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
            <Style TargetType="Label">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Padding" Value="0,0,8,0" />
            </Style>
            <Style TargetType="RadioButton">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,0,20,0" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Views Duplicator"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Duplicate selected views with optional renaming."
                       Margin="0,4,0,0"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12" />
        </StackPanel>

        <!-- Duplicate mode -->
        <Border Grid.Row="2"
                Padding="14,12"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Duplicate Mode"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="RbDuplicate"
                                 Content="Duplicate View"
                                 ToolTip="Creates an independent copy with no annotation elements." />
                    <RadioButton x:Name="RbDependent"
                                 Content="As Dependent"
                                 ToolTip="Creates a dependent copy that shares crop and scope with the parent." />
                    <RadioButton x:Name="RbWithDetailing"
                                 Content="With Detailing"
                                 IsChecked="True"
                                 ToolTip="Creates an independent copy including all annotation and detail elements." />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Source info -->
        <TextBlock x:Name="TxtSource"
                   Grid.Row="4"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="11"
                   Text="Source: Current selection" />

        <!-- Rename fields -->
        <Border Grid.Row="6"
                Padding="14,12"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Find:"
                       ToolTip="Text to find in the original view name. Leave blank to skip find/replace." />
                <TextBox x:Name="TxtFind" Grid.Row="0" Grid.Column="1"
                         ToolTip="Text to find in the original view name. Leave blank to skip find/replace." />

                <Label Grid.Row="2" Grid.Column="0" Content="Replace:"
                       ToolTip="Text to replace the found text with in the duplicate name." />
                <TextBox x:Name="TxtReplace" Grid.Row="2" Grid.Column="1"
                         ToolTip="Text to replace the found text with in the duplicate name." />

                <Label Grid.Row="4" Grid.Column="0" Content="Prefix:"
                       ToolTip="Text prepended to the duplicate view name. Applied after Find/Replace." />
                <TextBox x:Name="TxtPrefix" Grid.Row="4" Grid.Column="1"
                         ToolTip="Text prepended to the duplicate view name. Applied after Find/Replace." />

                <Label Grid.Row="6" Grid.Column="0" Content="Suffix:"
                       ToolTip="Text appended to the duplicate view name. Applied after Find/Replace." />
                <TextBox x:Name="TxtSuffix" Grid.Row="6" Grid.Column="1"
                         Text="-copy"
                         ToolTip="Text appended to the duplicate view name. Applied after Find/Replace." />
            </Grid>
        </Border>

        <!-- Buttons -->
        <DockPanel Grid.Row="8" Margin="0,16,0,0">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="BtnCancel"
                        MinWidth="90"
                        Margin="0,0,8,0"
                        Content="Cancel"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button x:Name="BtnDuplicate"
                        MinWidth="120"
                        Content="Duplicate"
                        IsDefault="True"
                        ToolTip="Duplicate the selected views with the specified rename settings." />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
