<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About WWPTools"
        Height="360"
        Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        KeyDown="handleclick"
        MouseDown="handleclick">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelText" Color="#243746"/>
        <SolidColorBrush x:Key="PanelAccent" Color="#1F78D1"/>
        <SolidColorBrush x:Key="PanelAccentSoft" Color="#E9F3FC"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PanelText}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="{StaticResource PanelText}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Margin" Value="4,4,4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelAccent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="18"
            Background="White"
            CornerRadius="18"
            BorderBrush="#D8E2EB"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.2" Color="#1D2D3A"/>
        </Border.Effect>

        <Grid Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="190"
                    Height="190"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{StaticResource PanelAccentSoft}"
                    CornerRadius="24">
                <Image x:Name="LogoImage"
                       Margin="24"
                       Stretch="Uniform" />
            </Border>

            <StackPanel Grid.Column="1" Margin="18,4,0,0">
                <TextBlock x:Name="TitleText"
                           FontSize="38"
                           FontWeight="SemiBold"
                           Text="WWPTools" />
                <TextBlock x:Name="SubtitleText"
                           Margin="0,4,0,0"
                           FontSize="15"
                           TextWrapping="Wrap"
                           Text="WW+P Revit productivity tools and automation workflows." />

                <WrapPanel Margin="0,14,0,0">
                    <Border Background="#EEF4FA" CornerRadius="10" Padding="10,4" Margin="0,0,8,8">
                        <TextBlock x:Name="VersionText" FontSize="13" FontWeight="SemiBold" Text="Version v1.2.8" />
                    </Border>
                    <Border x:Name="BranchBadge" Background="#EEF4FA" CornerRadius="10" Padding="10,4" Margin="0,0,8,8" Visibility="Collapsed">
                        <TextBlock x:Name="BranchText" FontSize="13" Text="Branch main" />
                    </Border>
                    <Border x:Name="CommitBadge" Background="#EEF4FA" CornerRadius="10" Padding="10,4" Margin="0,0,8,8" Visibility="Collapsed">
                        <TextBlock x:Name="CommitText" FontSize="13" Text="Commit abc1234" />
                    </Border>
                </WrapPanel>

                <TextBlock x:Name="BodyText"
                           Margin="0,4,0,0"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Text="Use this panel to quickly open WWP resources, release notes, and the GitHub repository." />

                <WrapPanel Margin="0,18,0,0">
                    <Button x:Name="WebsiteButton" Content="Website" />
                    <Button x:Name="GuidebookButton" Content="Guidebook" />
                    <Button x:Name="GithubButton" Content="GitHub" />
                    <Button x:Name="ReleaseButton" Content="Release Notes" />
                </WrapPanel>

                <TextBlock x:Name="FooterText"
                           Margin="0,20,0,0"
                           FontSize="12"
                           Foreground="#6A7E90"
                           Text="Click anywhere outside the panel or press Esc to close." />
            </StackPanel>
        </Grid>
    </Border>
</Window>
