<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Create Non-Rated Line for ALL Walls"
    Width="480" Height="280"
    MinWidth="400" MinHeight="240"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResizeWithGrip"
    Background="#F6F8FB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Create Lines for ALL Walls"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="#17324D" TextWrapping="Wrap"/>
            <TextBlock Text="Creates detail lines along the centerline of every wall in the current view."
                       FontSize="12" Foreground="#4F6478"
                       Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Line Style -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Line Style:"
                       VerticalAlignment="Center"
                       Foreground="#17324D" FontSize="13"/>
            <ComboBox Grid.Column="1" x:Name="CboLineStyle"
                      Height="32"
                      BorderBrush="#D9E2EC" BorderThickness="1"
                      FontSize="13"/>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="3" x:Name="LblStatus"
                   Foreground="#B42318" FontSize="12"
                   Margin="0,4,0,8" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="BtnCancel"
                    Content="Cancel" Width="90" Height="34"
                    FontSize="13"
                    Background="White" BorderBrush="#D9E2EC"
                    Foreground="#17324D" Cursor="Hand"/>
            <Button Grid.Column="3" x:Name="BtnRun"
                    Content="Create" Width="90" Height="34"
                    FontSize="13" FontWeight="SemiBold"
                    Background="#17324D" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
