<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Map FRR Values to Line Styles"
    Width="520" Height="360"
    MinWidth="420" MinHeight="300"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResizeWithGrip"
    Background="#F6F8FB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Map FRR Values to Line Styles"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="#17324D" TextWrapping="Wrap"/>
            <TextBlock Text="No matching line style was found for the values below. Select a line style for each, or choose &#x2014; Skip &#x2014; to ignore those walls."
                       FontSize="12" Foreground="#4F6478"
                       Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Dynamic mapping rows (filled from Python) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MappingPanel" Margin="0,0,0,4"/>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="2" x:Name="LblStatus"
                   Foreground="#B42318" FontSize="12"
                   Margin="0,4,0,8" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="BtnCancel"
                    Content="Cancel" Width="90" Height="34" FontSize="13"
                    Background="White" BorderBrush="#D9E2EC"
                    Foreground="#17324D" Cursor="Hand"/>
            <Button Grid.Column="3" x:Name="BtnOK"
                    Content="Apply" Width="90" Height="34"
                    FontSize="13" FontWeight="SemiBold"
                    Background="#17324D" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
